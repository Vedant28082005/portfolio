{
  // Cloudflare Workers configuration for Vedant Sutariya's portfolio.
  "name": "portfolio",
  "compatibility_date": "2024-09-23",
  // Custom worker script — handles SPA fallback (serves index.html for unknown paths)
  "main": "./src/worker.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
